{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "Architecture": {
      "description": "Target architecture.",
      "enum": [
        "x86",
        "x64",
        "arm32",
        "arm64",
        "neutral"
      ],
      "type": "string"
    },
    "CustomParameterString": {
      "maxLength": 512,
      "minLength": 1,
      "type": "string"
    },
    "Decision": {
      "description": "Policy decision.",
      "enum": [
        "allow",
        "deny"
      ],
      "type": "string"
    },
    "Elevation": {
      "description": "Requested elevation level.",
      "enum": [
        "standard",
        "elevated"
      ],
      "type": "string"
    },
    "FailureDecision": {
      "description": "Failure decision — always deny.",
      "enum": [
        "deny"
      ],
      "type": "string"
    },
    "HttpUrl": {
      "maxLength": 2048,
      "pattern": "^([Hh][Tt][Tt][Pp][Ss]?)://.+$",
      "type": "string"
    },
    "ManagerName": {
      "description": "Supported package manager names.",
      "enum": [
        "Winget",
        "PowerShell"
      ],
      "type": "string"
    },
    "Operation": {
      "description": "Package operation type.",
      "enum": [
        "install",
        "update",
        "uninstall"
      ],
      "type": "string"
    },
    "PolicyConstraints": {
      "additionalProperties": false,
      "description": "Constraints applied after a rule matches.",
      "properties": {
        "allowCustomInstallLocation": {
          "description": "Allow custom install location.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowCustomParameters": {
          "description": "Allow custom parameters.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowInteractive": {
          "description": "Allow interactive mode.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowKillBeforeOperation": {
          "description": "Allow killing processes before operation.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowPrePostCommands": {
          "description": "Allow pre/post operation commands.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowPreRelease": {
          "description": "Allow pre-release versions.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowRunAsAdministrator": {
          "description": "Allow running as administrator.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowSkipHashCheck": {
          "description": "Allow skipping hash verification.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowedCustomParameterPatterns": {
          "description": "Glob patterns for allowed custom parameters.",
          "items": {
            "$ref": "#/definitions/CustomParameterString"
          },
          "maxItems": 128,
          "type": [
            "array",
            "null"
          ]
        },
        "allowedCustomParameters": {
          "description": "Exact allowed custom parameters.",
          "items": {
            "$ref": "#/definitions/CustomParameterString"
          },
          "maxItems": 128,
          "type": [
            "array",
            "null"
          ]
        },
        "allowedInstallLocationPatterns": {
          "description": "Glob patterns for allowed install locations.",
          "items": {
            "$ref": "#/definitions/StringPattern"
          },
          "maxItems": 64,
          "type": [
            "array",
            "null"
          ]
        },
        "deniedCustomParameters": {
          "description": "Denied custom parameters (deny takes precedence over allow).",
          "items": {
            "$ref": "#/definitions/CustomParameterString"
          },
          "maxItems": 128,
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PolicyEnforcement": {
      "additionalProperties": false,
      "description": "Enforcement configuration.",
      "properties": {
        "auditMode": {
          "description": "When true, broker logs decisions but does not enforce.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "defaultDecision": {
          "allOf": [
            {
              "$ref": "#/definitions/Decision"
            }
          ],
          "description": "Decision when no rule matches."
        },
        "failureDecision": {
          "allOf": [
            {
              "$ref": "#/definitions/FailureDecision"
            }
          ],
          "description": "Decision on validation/parsing failure (must be \"deny\")."
        },
        "rulePrecedence": {
          "allOf": [
            {
              "$ref": "#/definitions/RulePrecedence"
            }
          ],
          "description": "Rule precedence strategy (must be \"priorityThenDeny\")."
        }
      },
      "required": [
        "defaultDecision",
        "failureDecision",
        "rulePrecedence"
      ],
      "type": "object"
    },
    "PolicyMatch": {
      "additionalProperties": false,
      "description": "Match criteria for a policy rule. All specified fields must match. At least one field must be present.",
      "properties": {
        "architectures": {
          "description": "Allowed architectures.",
          "items": {
            "$ref": "#/definitions/Architecture"
          },
          "maxItems": 5,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "elevation": {
          "description": "Allowed elevation levels.",
          "items": {
            "$ref": "#/definitions/Elevation"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "hasCustomInstallLocation": {
          "description": "Whether request has custom install location.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "hasCustomParameters": {
          "description": "Whether request has custom parameters.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "hasKillBeforeOperation": {
          "description": "Whether request has kill-before-operation entries.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "hasPrePostCommands": {
          "description": "Whether request has pre/post operation commands.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "interactive": {
          "description": "Allowed interactive values.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "managers": {
          "description": "Allowed managers.",
          "items": {
            "$ref": "#/definitions/ManagerName"
          },
          "maxItems": 16,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "operations": {
          "description": "Allowed operations.",
          "items": {
            "$ref": "#/definitions/Operation"
          },
          "maxItems": 3,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "packageIdentifiers": {
          "description": "Package identifier patterns (wildcard).",
          "items": {
            "$ref": "#/definitions/StringPattern"
          },
          "maxItems": 1024,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "packageNames": {
          "description": "Package name patterns (wildcard).",
          "items": {
            "$ref": "#/definitions/StringPattern"
          },
          "maxItems": 1024,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "preRelease": {
          "description": "Allowed preRelease values.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "runAsAdministrator": {
          "description": "Allowed runAsAdministrator values.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "scopes": {
          "description": "Allowed scopes.",
          "items": {
            "$ref": "#/definitions/Scope"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "skipHashCheck": {
          "description": "Allowed skipHashCheck values.",
          "items": {
            "type": "boolean"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "sources": {
          "description": "Source patterns (wildcard).",
          "items": {
            "$ref": "#/definitions/StringPattern"
          },
          "maxItems": 128,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "versionRange": {
          "anyOf": [
            {
              "$ref": "#/definitions/VersionRange"
            },
            {
              "type": "null"
            }
          ],
          "description": "Semantic version range."
        },
        "versions": {
          "description": "Exact version list.",
          "items": {
            "$ref": "#/definitions/VersionString"
          },
          "maxItems": 256,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PolicyMetadata": {
      "additionalProperties": false,
      "description": "Policy metadata.",
      "properties": {
        "description": {
          "description": "Human-readable description.",
          "maxLength": 512,
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "allOf": [
            {
              "$ref": "#/definitions/ResourceId"
            }
          ],
          "description": "Unique policy identifier."
        },
        "publishedAt": {
          "description": "ISO 8601 publication timestamp (RFC 3339).",
          "format": "date-time",
          "type": "string"
        },
        "publisher": {
          "description": "Organization that published the policy.",
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        "revision": {
          "description": "Monotonically increasing revision number.",
          "format": "uint32",
          "maximum": 2147483647.0,
          "minimum": 1.0,
          "type": "integer"
        },
        "supportUrl": {
          "anyOf": [
            {
              "$ref": "#/definitions/HttpUrl"
            },
            {
              "type": "null"
            }
          ],
          "description": "URL for support or documentation."
        },
        "validFrom": {
          "description": "Policy becomes active at this time.",
          "format": "date-time",
          "type": "string"
        },
        "validUntil": {
          "description": "Policy expires at this time.",
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "id",
        "publishedAt",
        "publisher",
        "revision"
      ],
      "type": "object"
    },
    "PolicyRule": {
      "additionalProperties": false,
      "description": "A single policy rule.",
      "properties": {
        "constraints": {
          "anyOf": [
            {
              "$ref": "#/definitions/PolicyConstraints"
            },
            {
              "type": "null"
            }
          ],
          "description": "Additional constraints applied after matching."
        },
        "decision": {
          "allOf": [
            {
              "$ref": "#/definitions/Decision"
            }
          ],
          "description": "Decision if this rule matches."
        },
        "description": {
          "description": "Human-readable description.",
          "maxLength": 512,
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "default": true,
          "description": "Whether the rule is active.",
          "type": "boolean"
        },
        "id": {
          "allOf": [
            {
              "$ref": "#/definitions/ResourceId"
            }
          ],
          "description": "Unique rule identifier."
        },
        "match": {
          "allOf": [
            {
              "$ref": "#/definitions/PolicyMatch"
            }
          ],
          "description": "Match criteria — request must satisfy all specified fields."
        },
        "priority": {
          "description": "Priority (lower = higher precedence).",
          "format": "uint32",
          "maximum": 2147483647.0,
          "minimum": 0.0,
          "type": "integer"
        },
        "reason": {
          "description": "Reason reported to the client.",
          "maxLength": 512,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "decision",
        "id",
        "match",
        "priority"
      ],
      "type": "object"
    },
    "PolicyType": {
      "description": "Fixed policy type value: `\"packageBrokerPolicy\"`.",
      "enum": [
        "packageBrokerPolicy"
      ],
      "type": "string"
    },
    "ResourceId": {
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:\\-]{0,127}$",
      "type": "string"
    },
    "RulePrecedence": {
      "description": "Rule precedence strategy — always priorityThenDeny.",
      "enum": [
        "priorityThenDeny"
      ],
      "type": "string"
    },
    "Scope": {
      "description": "Package installation scope.",
      "enum": [
        "user",
        "machine"
      ],
      "type": "string"
    },
    "SemanticVersion": {
      "maxLength": 128,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "type": "string"
    },
    "StringPattern": {
      "maxLength": 256,
      "minLength": 1,
      "type": "string"
    },
    "VersionRange": {
      "additionalProperties": false,
      "description": "Semantic version range for matching.",
      "properties": {
        "includePrerelease": {
          "default": false,
          "description": "Whether to include pre-release versions.",
          "type": "boolean"
        },
        "maxVersion": {
          "description": "Maximum version (inclusive).",
          "maxLength": 128,
          "minLength": 1,
          "type": [
            "string",
            "null"
          ]
        },
        "minVersion": {
          "description": "Minimum version (inclusive).",
          "maxLength": 128,
          "minLength": 1,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "VersionString": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    }
  },
  "description": "A policy document governing which package operations are allowed or denied.",
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "$ref": "#/definitions/HttpUrl"
        },
        {
          "type": "null"
        }
      ],
      "description": "JSON Schema URI (ignored at runtime)."
    },
    "enforcement": {
      "allOf": [
        {
          "$ref": "#/definitions/PolicyEnforcement"
        }
      ],
      "description": "Enforcement configuration."
    },
    "metadata": {
      "allOf": [
        {
          "$ref": "#/definitions/PolicyMetadata"
        }
      ],
      "description": "Policy metadata."
    },
    "policyType": {
      "allOf": [
        {
          "$ref": "#/definitions/PolicyType"
        }
      ],
      "description": "Must be `\"packageBrokerPolicy\"`."
    },
    "policyVersion": {
      "allOf": [
        {
          "$ref": "#/definitions/SemanticVersion"
        }
      ],
      "description": "Policy syntax version (semver)."
    },
    "rules": {
      "description": "Ordered list of policy rules.",
      "items": {
        "$ref": "#/definitions/PolicyRule"
      },
      "maxItems": 1024,
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "enforcement",
    "metadata",
    "policyType",
    "policyVersion",
    "rules"
  ],
  "title": "PolicyDocument",
  "type": "object"
}