#!/bin/sh

set -e

if [ ! -d /etc/devolutions-gateway ]; then
	/bin/mkdir /etc/devolutions-gateway
fi
/bin/chmod 750 /etc/devolutions-gateway

if [ ! -f /etc/devolutions-gateway/gateway.json ]; then
	/usr/bin/devolutions-gateway --config-init-only >/dev/null || true
fi
if [ -f /etc/devolutions-gateway/gateway.json ]; then
	/bin/chmod 600 /etc/devolutions-gateway/gateway.json
fi

# Automatically added by dh_installsystemd/13.18ubuntu2.1
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	# The following line should be removed in trixie or trixie+1
	deb-systemd-helper unmask 'devolutions-gateway.service' >/dev/null || true

	# was-enabled defaults to true, so new installations run enable.
	if deb-systemd-helper --quiet was-enabled 'devolutions-gateway.service'; then
		# Enables the unit on first installation, creates new
		# symlinks on upgrades if the unit file has changed.
		deb-systemd-helper enable 'devolutions-gateway.service' >/dev/null || true
	else
		# Update the statefile to add new symlinks (if any), which need to be
		# cleaned up on purge. Also remove old symlinks.
		deb-systemd-helper update-state 'devolutions-gateway.service' >/dev/null || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.18ubuntu2.1
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "${DPKG_ROOT:-}" ] && [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'devolutions-gateway.service' >/dev/null || true
	fi
fi
# End automatically added section

if [ "$1" = "configure" ] && [ -z "$2" ]; then
	echo ""
	echo "Devolutions Gateway has been installed."
	echo "Edit /etc/devolutions-gateway/gateway.json, then run:"
	if [ -d /run/systemd/system ]; then
		echo "  systemctl start devolutions-gateway"
	else
		echo "  Start devolutions-gateway using your init system or run it directly."
	fi
	echo ""
fi
