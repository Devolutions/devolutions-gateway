#!/bin/sh

set -e

if [ ! -d /etc/devolutions-gateway ]; then
	/bin/mkdir /etc/devolutions-gateway
fi
/bin/chmod 750 /etc/devolutions-gateway

if [ ! -f /etc/devolutions-gateway/gateway.json ]; then
	/usr/bin/devolutions-gateway --config-init-only >/dev/null || true
fi
if [ -f /etc/devolutions-gateway/gateway.json ]; then
	/bin/chmod 600 /etc/devolutions-gateway/gateway.json
fi

# Equivalent to %systemd_post: reload units, then preset (enable) on fresh install only.
if [ -d /run/systemd/system ]; then
	systemctl daemon-reload >/dev/null 2>&1 || true
	if [ "$1" -eq 1 ]; then
		systemctl preset devolutions-gateway.service >/dev/null 2>&1 || true
	fi
fi

if [ "$1" -eq 1 ]; then
	echo ""
	echo "Devolutions Gateway has been installed."
	echo "Edit /etc/devolutions-gateway/gateway.json, then run:"
	if [ -d /run/systemd/system ]; then
		echo "  systemctl start devolutions-gateway"
	else
		echo "  Start devolutions-gateway using your init system or run it directly."
	fi
	echo ""
fi
